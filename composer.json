{
    "name": "zakobo/scramble-sso-auth-driver",
    "description": "Zakobo SSO authentication and Swagger UI integration for Scramble.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "dedoc/scramble": "^0.13.22",
        "illuminate/contracts": "^13.0",
        "illuminate/routing": "^13.0",
        "illuminate/support": "^13.0",
        "illuminate/view": "^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^11.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Zakobo\\ScrambleSsoAuthDriver\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Zakobo\\ScrambleSsoAuthDriver\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": [
            "./vendor/bin/phpunit"
        ],
        "analyse": [
            "./vendor/bin/phpstan analyse --memory-limit=2G"
        ],
        "lint": [
            "./vendor/bin/pint --parallel"
        ],
        "lint:check": [
            "./vendor/bin/pint --test"
        ],
        "lint:dirty": [
            "./vendor/bin/pint --dirty"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Zakobo\\ScrambleSsoAuthDriver\\ScrambleSsoAuthDriverServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
